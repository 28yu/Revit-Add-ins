<Window x:Class="Tools28.Commands.BeamUnderLevel.BeamUnderLevelDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="梁下端色分け"
        Width="700"
        Height="850"
        MinWidth="600"
        MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <!-- カラー定義 -->
        <SolidColorBrush x:Key="RevitBlue" Color="#0066CC"/>
        <SolidColorBrush x:Key="RevitHoverBlue" Color="#0052A3"/>
        <SolidColorBrush x:Key="RevitDarkGray" Color="#333333"/>
        <SolidColorBrush x:Key="RevitLightGray" Color="#E6E6E6"/>

        <!-- セクションヘッダースタイル -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource RevitDarkGray}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- ラベルスタイル -->
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource RevitDarkGray}"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>

        <!-- 値表示スタイル -->
        <Style x:Key="ValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource RevitBlue}"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>

        <!-- 注釈スタイル -->
        <Style x:Key="NoteStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>

        <!-- 実行ボタンスタイル -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="90"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Margin" Value="5,0,0,0"/>
            <Setter Property="Background" Value="{StaticResource RevitBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource RevitBlue}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource RevitHoverBlue}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource RevitHoverBlue}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="{StaticResource RevitLightGray}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource RevitLightGray}"/>
                    <Setter Property="Foreground" Value="#999999"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- セカンダリボタンスタイル -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="90"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Margin" Value="5,0,0,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource RevitDarkGray}"/>
            <Setter Property="BorderBrush" Value="#ADADAD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E5F3FF"/>
                    <Setter Property="BorderBrush" Value="#0078D7"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- コンボボックススタイル -->
        <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="BorderBrush" Value="{StaticResource RevitLightGray}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ステップインジケーター -->
        <Border Grid.Row="0" Background="White" BorderBrush="#D3D3D3"
                BorderThickness="0,0,0,1" Padding="20,12">
            <TextBlock x:Name="StepIndicator" FontSize="14" FontWeight="Bold"
                       Foreground="{StaticResource RevitDarkGray}"
                       Text="ステップ 1 / 4  レベル設定、凡例設定"/>
        </Border>

        <!-- ステップ内容 -->
        <Grid Grid.Row="1" Margin="20,15,20,10">
            <!-- ステップ1: レベル設定 -->
            <Grid x:Name="Step1Panel" Visibility="Visible">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- ビュー情報 -->
                <Border Grid.Row="0" Background="White" BorderBrush="#D3D3D3"
                        BorderThickness="1" CornerRadius="3" Padding="15,12" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock x:Name="txtViewInfo" Style="{StaticResource SectionHeader}" Text="ビュー情報"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock x:Name="txtViewName" Grid.Row="0" Grid.Column="0" Style="{StaticResource LabelStyle}"
                                       Text="ビュー名:"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource ValueStyle}"
                                       x:Name="ViewNameText"/>

                            <TextBlock x:Name="txtBeamCount" Grid.Row="1" Grid.Column="0" Style="{StaticResource LabelStyle}"
                                       Text="梁数:"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource ValueStyle}"
                                       x:Name="BeamCountText"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 文字タイプ設定 -->
                <Border Grid.Row="1" Background="White" BorderBrush="#D3D3D3"
                        BorderThickness="1" CornerRadius="3" Padding="15,12" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock x:Name="txtTextTypeSetting" Style="{StaticResource SectionHeader}" Text="文字タイプ設定"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock x:Name="txtLegendTextType" Grid.Row="0" Grid.Column="0" Style="{StaticResource LabelStyle}"
                                       Text="凡例の文字タイプ:" VerticalAlignment="Center"/>
                            <ComboBox Grid.Row="0" Grid.Column="1"
                                      x:Name="TextNoteTypeComboBox"
                                      Style="{StaticResource ComboBoxStyle}"/>

                            <TextBlock x:Name="txtLabelTextType" Grid.Row="2" Grid.Column="0" Style="{StaticResource LabelStyle}"
                                       Text="梁ラベルの文字タイプ:" VerticalAlignment="Center"/>
                            <ComboBox Grid.Row="2" Grid.Column="1"
                                      x:Name="BeamLabelTypeComboBox"
                                      Style="{StaticResource ComboBoxStyle}"/>
                        </Grid>
                        <TextBlock x:Name="txtTextTypeHint" Style="{StaticResource NoteStyle}"
                                   Text="※ 凡例は製図ビューの文字、梁ラベルは天井伏図上の梁に表示する文字です"/>
                    </StackPanel>
                </Border>

                <!-- レベル設定 -->
                <Border Grid.Row="2" Background="White" BorderBrush="#D3D3D3"
                        BorderThickness="1" CornerRadius="3" Padding="15,12" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock x:Name="txtLevelSetting" Style="{StaticResource SectionHeader}" Text="レベル設定"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock x:Name="txtRefLevel" Grid.Row="0" Grid.Column="0" Style="{StaticResource LabelStyle}"
                                       Text="参照レベル:" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource ValueStyle}"
                                       x:Name="RefLevelText" VerticalAlignment="Center"/>

                            <TextBlock x:Name="txtUpperLevel" Grid.Row="2" Grid.Column="0" Style="{StaticResource LabelStyle}"
                                       Text="上位レベル:" VerticalAlignment="Center"/>
                            <ComboBox Grid.Row="2" Grid.Column="1"
                                      x:Name="LowerLevelComboBox"
                                      Style="{StaticResource ComboBoxStyle}"
                                      SelectionChanged="LowerLevelComboBox_SelectionChanged"/>

                            <TextBlock x:Name="txtFloorHeight" Grid.Row="4" Grid.Column="0" Style="{StaticResource LabelStyle}"
                                       Text="階高:" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Style="{StaticResource ValueStyle}"
                                       x:Name="FloorHeightText" VerticalAlignment="Center"/>
                        </Grid>
                        <TextBlock x:Name="txtLevelHint" Style="{StaticResource NoteStyle}"
                                   Text="※ 参照レベルを基準として梁下端レベルを算出します"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ステップ2: パラメータ選択 -->
            <Grid x:Name="Step2Panel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,10">
                    <TextBlock x:Name="txtHeightParam" Style="{StaticResource SectionHeader}" Text="梁高さパラメータ選択"/>
                    <TextBlock x:Name="txtHeightParamHint" Style="{StaticResource NoteStyle}"
                               Text="※ ファミリ毎に梁高さとして使用するパラメータを選択してください"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="FamilyParamPanel"/>
                </ScrollViewer>
            </Grid>

            <!-- ステップ3: 梁天端レベルパラメータ選択 -->
            <Grid x:Name="Step3Panel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,10">
                    <TextBlock Style="{StaticResource SectionHeader}" Text="梁天端レベルパラメータ選択"/>
                    <TextBlock Style="{StaticResource NoteStyle}"
                               Text="※ ファミリ毎に梁天端レベル（参照レベルからのオフセット）として使用するパラメータを選択してください"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="FamilyTopLevelParamPanel"/>
                </ScrollViewer>
            </Grid>

            <!-- ステップ4: 確認・実行 -->
            <ScrollViewer x:Name="Step4Panel" Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- 処理概要 -->
                    <Border Background="White" BorderBrush="#D3D3D3"
                            BorderThickness="1" CornerRadius="3" Padding="15,12" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionHeader}" Text="処理概要"/>
                            <TextBlock x:Name="SummaryText" Style="{StaticResource LabelStyle}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- 処理内容 -->
                    <Border Background="White" BorderBrush="#D3D3D3"
                            BorderThickness="1" CornerRadius="3" Padding="15,12" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionHeader}" Text="処理内容"/>
                            <StackPanel>
                                <CheckBox Content="共有パラメータ作成・バインド"
                                          IsChecked="True" IsEnabled="False" Margin="0,3"/>
                                <CheckBox Content="梁下レベル値の計算・書き込み"
                                          IsChecked="True" IsEnabled="False" Margin="0,3"/>
                                <CheckBox Content="フィルタ自動作成・色分け"
                                          IsChecked="True" IsEnabled="False" Margin="0,3"/>
                                <CheckBox Content="凡例の製図ビュー作成"
                                          IsChecked="True" IsEnabled="False" Margin="0,3"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- 既存フィルタ上書き確認 -->
                    <Border Background="#FFF8E1" BorderBrush="#FFD54F"
                            BorderThickness="1" CornerRadius="3" Padding="15,12">
                        <StackPanel>
                            <TextBlock FontSize="12" FontWeight="Bold" Foreground="#F57F17"
                                       Text="既存フィルタについて" Margin="0,0,0,5"/>
                            <CheckBox x:Name="OverwriteCheckBox" IsChecked="True"
                                      Content="既存の「梁下_」フィルタを上書きする"
                                      FontSize="11" Margin="0,3"/>
                            <TextBlock Style="{StaticResource NoteStyle}"
                                       Text="※ チェックを外すと既存フィルタはそのまま残ります"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ボタンエリア -->
        <Border Grid.Row="2" Background="White" BorderBrush="#D3D3D3"
                BorderThickness="0,1,0,0" Padding="20,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BackButton" Content="戻る"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="BackButton_Click"
                        IsEnabled="False"/>
                <Button x:Name="NextButton" Content="次へ"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="NextButton_Click"/>
                <Button Content="キャンセル"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="CancelButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
