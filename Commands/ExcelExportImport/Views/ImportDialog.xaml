<Window x:Class="Tools28.Commands.ExcelExportImport.Views.ImportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EXCELインポート"
        Width="700"
        Height="500"
        MinWidth="550"
        MinHeight="400"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Window.Resources>
        <SolidColorBrush x:Key="RevitBlue" Color="#0066CC"/>
        <SolidColorBrush x:Key="RevitHoverBlue" Color="#0052A3"/>
        <SolidColorBrush x:Key="RevitDarkGray" Color="#333333"/>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="80"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
            <Setter Property="Background" Value="{StaticResource RevitBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource RevitBlue}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource RevitHoverBlue}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource RevitHoverBlue}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#CCCCCC"/>
                    <Setter Property="BorderBrush" Value="#CCCCCC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="70"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource RevitDarkGray}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0F0F0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ファイル選択 -->
        <GroupBox Grid.Row="0" Header="Excelファイル" FontSize="12" Margin="0,0,0,8">
            <Grid Margin="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="FilePathTextBox" Grid.Column="0"
                         IsReadOnly="True" FontSize="11" Padding="4,2"
                         BorderBrush="#CCCCCC"/>
                <Button Grid.Column="1" Content="開いているファイル"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="4,0,0,0"
                        Click="OpenFilesButton_Click"/>
                <Button Grid.Column="2" Content="参照..."
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="4,0,0,0"
                        Click="BrowseButton_Click"/>
            </Grid>
        </GroupBox>

        <!-- シート情報 -->
        <GroupBox Grid.Row="1" Header="シート情報" FontSize="12" Margin="0,0,0,8">
            <TextBlock x:Name="SheetInfoText" FontSize="11" Margin="8,4"
                       Text="Excelファイルを選択してください"
                       Foreground="#666666"/>
        </GroupBox>

        <!-- プレビュー -->
        <GroupBox Grid.Row="2" Header="変更プレビュー" FontSize="12">
            <DataGrid x:Name="PreviewDataGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserSortColumns="True"
                      CanUserResizeColumns="True"
                      FontSize="11"
                      BorderThickness="0"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      AlternatingRowBackground="#F9F9F9">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="要素ID" Binding="{Binding ElementId}" Width="80" SortMemberPath="ElementId"/>
                    <DataGridTextColumn Header="カテゴリ" Binding="{Binding CategoryName}" Width="100" SortMemberPath="CategoryName"/>
                    <DataGridTextColumn Header="パラメータ" Binding="{Binding ParameterName}" Width="120" SortMemberPath="ParameterName"/>
                    <DataGridTextColumn Header="現在値" Binding="{Binding CurrentValue}" Width="*" SortMemberPath="CurrentValue"/>
                    <DataGridTextColumn Header="新しい値" Binding="{Binding NewValue}" Width="*" SortMemberPath="NewValue"/>
                </DataGrid.Columns>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsReadOnly}" Value="True">
                                <Setter Property="Foreground" Value="#999999"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
            </DataGrid>
        </GroupBox>

        <!-- サマリー -->
        <TextBlock x:Name="SummaryText" Grid.Row="3" FontSize="11"
                   Margin="4,8,4,4" Foreground="#666666"/>

        <!-- ボタンエリア -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
            <Button x:Name="ImportButton" Content="インポート実行"
                    Style="{StaticResource PrimaryButtonStyle}"
                    IsEnabled="False"
                    Click="ImportButton_Click"/>
            <Button Content="キャンセル" Style="{StaticResource SecondaryButtonStyle}"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
