<Window x:Class="Tools28.Commands.ExcelExportImport.Views.ScopeSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EXCELエクスポート"
        SizeToContent="Height"
        Width="360"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="White">
    <Window.Resources>
        <Style x:Key="ScopeButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Background" Value="#F5F7FB"/>
            <Setter Property="BorderBrush" Value="#D5DBE3"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#222222"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E4ECFA"/>
                    <Setter Property="BorderBrush" Value="#0066CC"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#999999"/>
                    <Setter Property="Background" Value="#F0F0F0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#CCCCCC" BorderThickness="1">
        <StackPanel Margin="16">
            <TextBlock x:Name="TitleText" Text="書出し範囲の選択"
                       FontSize="15" FontWeight="Bold"
                       Foreground="#222222"
                       Margin="0,0,0,6"/>
            <TextBlock x:Name="DescriptionText" Text="書出す要素の範囲を選択してください。"
                       FontSize="12" Foreground="#555555"
                       TextWrapping="Wrap"
                       Margin="0,0,0,10"/>

            <Button x:Name="btnProject" Style="{StaticResource ScopeButtonStyle}"
                    Click="btnProject_Click">
                <TextBlock x:Name="ProjectText" Text="&#x2192;  プロジェクト全体の要素"/>
            </Button>
            <Button x:Name="btnView" Style="{StaticResource ScopeButtonStyle}"
                    Click="btnView_Click">
                <TextBlock x:Name="ViewText" Text="&#x2192;  現在のビューにある要素"/>
            </Button>
            <Button x:Name="btnSelection" Style="{StaticResource ScopeButtonStyle}"
                    Click="btnSelection_Click">
                <TextBlock x:Name="SelectionText" Text="&#x2192;  現在選択されている要素"/>
            </Button>
        </StackPanel>
    </Border>
</Window>
