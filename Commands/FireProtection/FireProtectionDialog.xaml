<Window x:Class="Tools28.Commands.FireProtection.FireProtectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="耐火被覆 色分け"
        Width="640"
        Height="640"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <SolidColorBrush x:Key="RevitBlue" Color="#0066CC"/>
        <SolidColorBrush x:Key="RevitHoverBlue" Color="#0052A3"/>
        <SolidColorBrush x:Key="RevitDarkGray" Color="#333333"/>
        <SolidColorBrush x:Key="RevitLightGray" Color="#E6E6E6"/>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource RevitDarkGray}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource RevitDarkGray}"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>
        <Style x:Key="ValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource RevitBlue}"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>
        <Style x:Key="NoteStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="90"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Margin" Value="5,0,0,0"/>
            <Setter Property="Background" Value="{StaticResource RevitBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource RevitBlue}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource RevitHoverBlue}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource RevitHoverBlue}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="{StaticResource RevitLightGray}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource RevitLightGray}"/>
                    <Setter Property="Foreground" Value="#999999"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="90"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Margin" Value="5,0,0,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource RevitDarkGray}"/>
            <Setter Property="BorderBrush" Value="#ADADAD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E5F3FF"/>
                    <Setter Property="BorderBrush" Value="#0078D7"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="BorderBrush" Value="{StaticResource RevitLightGray}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Step Indicator -->
        <Border Grid.Row="0" Background="White" BorderBrush="#D3D3D3"
                BorderThickness="0,0,0,1" Padding="20,12">
            <TextBlock x:Name="StepIndicator" FontSize="14" FontWeight="Bold"
                       Foreground="{StaticResource RevitDarkGray}"
                       Text="ステップ 1 / 3  基本設定"/>
        </Border>

        <!-- Step Content -->
        <Grid Grid.Row="1" Margin="20,15,20,10">

            <!-- Step 1: 基本設定 -->
            <ScrollViewer x:Name="Step1Panel" Visibility="Visible"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- パラメータ選択 -->
                    <Border Background="White" BorderBrush="#D3D3D3"
                            BorderThickness="1" CornerRadius="3" Padding="15,12" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionHeader}" Text="耐火被覆パラメータ"/>
                            <ComboBox x:Name="ParameterComboBox" Style="{StaticResource ComboBoxStyle}"
                                      SelectionChanged="Parameter_Changed"/>
                            <TextBlock x:Name="ParameterNoteText" Style="{StaticResource NoteStyle}"
                                       Text="※「耐火被覆」を含むパラメータを自動検出します"/>
                        </StackPanel>
                    </Border>

                    <!-- 検出された種類一覧 -->
                    <Border Background="White" BorderBrush="#D3D3D3"
                            BorderThickness="1" CornerRadius="3" Padding="15,12" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionHeader}" Text="検出された耐火被覆の種類"/>
                            <TextBlock Margin="0,0,0,6" FontSize="10" Foreground="Red"
                                       Text="※ 色の四角をクリックすると変更できます"/>
                            <StackPanel x:Name="DetectedTypesPanel"/>
                        </StackPanel>
                    </Border>

                    <!-- オフセット設定 -->
                    <Border Background="White" BorderBrush="#D3D3D3"
                            BorderThickness="1" CornerRadius="3" Padding="15,12" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionHeader}" Text="塗り潰し領域のオフセット設定"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <RadioButton x:Name="CommonOffsetRadio" Content="共通オフセット"
                                             GroupName="OffsetMode"
                                             IsChecked="True" FontSize="12"
                                             VerticalAlignment="Center" Margin="0,0,15,0"
                                             Checked="OffsetMode_Changed"/>
                                <TextBox x:Name="CommonOffsetInput" Width="80" Height="26"
                                         FontSize="12" Padding="4,2" Text="200"
                                         VerticalContentAlignment="Center"/>
                                <TextBlock Text=" mm" FontSize="12"
                                           VerticalAlignment="Center" Margin="4,0,0,0"/>
                            </StackPanel>
                            <RadioButton x:Name="PerTypeOffsetRadio" Content="種類ごとに個別オフセット"
                                         GroupName="OffsetMode"
                                         FontSize="12" Margin="0,0,0,4"
                                         Checked="OffsetMode_Changed"/>
                            <StackPanel x:Name="PerTypeOffsetPanel"/>
                            <TextBlock Style="{StaticResource NoteStyle}"
                                       Text="※ 梁のエッジからの距離（mm）"/>

                            <!-- 梁オフセットプレビュー図（平面図） -->
                            <Border BorderBrush="#CCC" BorderThickness="1" Margin="0,8,0,0"
                                    Padding="4" CornerRadius="2" Background="#FAFAFA"
                                    HorizontalAlignment="Center">
                                <Canvas Width="200" Height="120">
                                    <!-- 青塗り（オフセット領域全体） -->
                                    <Rectangle Canvas.Left="15" Canvas.Top="5" Width="170" Height="110"
                                               Fill="#64B5F6"/>
                                    <!-- 梁上面線 -->
                                    <Line X1="15" Y1="20" X2="185" Y2="20" Stroke="#333" StrokeThickness="1.5"/>
                                    <!-- 梁下面線 -->
                                    <Line X1="15" Y1="95" X2="185" Y2="95" Stroke="#333" StrokeThickness="1.5"/>
                                    <!-- 梁中心線（一点鎖線） -->
                                    <Line X1="0" Y1="57" X2="200" Y2="57" Stroke="#333" StrokeThickness="1"
                                          StrokeDashArray="8 3 2 3"/>
                                    <!-- ▽梁面テキスト -->
                                    <TextBlock Canvas.Left="30" Canvas.Top="24" Text="▽ 梁面" FontSize="12"
                                               Foreground="#333" FontWeight="Bold"/>
                                    <!-- A寸法線（梁面→オフセット上端）縦線 -->
                                    <Line X1="135" Y1="20" X2="135" Y2="5" Stroke="#CC0000" StrokeThickness="1"/>
                                    <Ellipse Canvas.Left="133" Canvas.Top="3" Width="4" Height="4" Fill="#CC0000"/>
                                    <Ellipse Canvas.Left="133" Canvas.Top="18" Width="4" Height="4" Fill="#CC0000"/>
                                    <!-- A寸法線 横引出線 -->
                                    <Line X1="135" Y1="5" X2="145" Y2="5" Stroke="#333" StrokeThickness="0.5"/>
                                    <Line X1="135" Y1="20" X2="145" Y2="20" Stroke="#333" StrokeThickness="0.5"/>
                                    <!-- Aテキスト -->
                                    <TextBlock Canvas.Left="125" Canvas.Top="6" Text="A" FontSize="12"
                                               Foreground="#CC0000" FontWeight="Bold"/>
                                </Canvas>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Step 2: 柱設定・表示設定 -->
            <ScrollViewer x:Name="Step2Panel" Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- 柱設定（平面/天伏ビューのみ） -->
                    <Border x:Name="ColumnSettingsPanel" Background="White" BorderBrush="#D3D3D3"
                            BorderThickness="1" CornerRadius="3" Padding="15,12" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionHeader}" Text="柱 耐火被覆設定"/>
                            <StackPanel Orientation="Horizontal">
                                <!-- 左: 入力欄 -->
                                <StackPanel Margin="0,0,60,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="8"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource LabelStyle}"
                                                   Text="A: 柱中心からの距離:" VerticalAlignment="Center"/>
                                        <TextBox Grid.Row="0" Grid.Column="1" x:Name="ColumnAInput"
                                                 Height="26" FontSize="12" Padding="4,2" Text="400"
                                                 VerticalContentAlignment="Center"/>
                                        <TextBlock Grid.Row="0" Grid.Column="2" Text=" mm" FontSize="12"
                                                   VerticalAlignment="Center" Margin="4,0,0,0"/>
                                        <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource LabelStyle}"
                                                   Text="B: 外側の幅:" VerticalAlignment="Center"/>
                                        <TextBox Grid.Row="2" Grid.Column="1" x:Name="ColumnBInput"
                                                 Height="26" FontSize="12" Padding="4,2" Text="150"
                                                 VerticalContentAlignment="Center"/>
                                        <TextBlock Grid.Row="2" Grid.Column="2" Text=" mm" FontSize="12"
                                                   VerticalAlignment="Center" Margin="4,0,0,0"/>
                                    </Grid>
                                    <TextBlock Style="{StaticResource NoteStyle}" Margin="0,6,0,0"
                                               Text="※ 柱中心からA、そこから外側にB幅"/>
                                </StackPanel>

                                <!-- 右: プレビュー図 -->
                                <Border BorderBrush="#CCC" BorderThickness="1"
                                        Padding="4" CornerRadius="2" Background="#FAFAFA">
                                    <Canvas Width="140" Height="140">
                                        <!-- 外側矩形 (A+B範囲) = 青塗り 正方形 -->
                                        <Rectangle Canvas.Left="10" Canvas.Top="25" Width="115" Height="115"
                                                   Fill="#2196F3" Stroke="#1976D2" StrokeThickness="1"/>
                                        <!-- 内側矩形 (A範囲) = 白抜き 正方形 -->
                                        <Rectangle Canvas.Left="25" Canvas.Top="40" Width="85" Height="85"
                                                   Fill="White" Stroke="#1976D2" StrokeThickness="1"/>
                                        <!-- 柱本体 正方形 -->
                                        <Rectangle Canvas.Left="40" Canvas.Top="55" Width="55" Height="55"
                                                   Fill="White" Stroke="#333" StrokeThickness="3" RadiusX="4" RadiusY="4"/>
                                        <TextBlock Canvas.Left="54" Canvas.Top="72" Text="柱" FontSize="12"
                                                   Foreground="#333" FontWeight="Bold"/>
                                        <!-- 柱中心線（縦） -->
                                        <Line X1="67" Y1="20" X2="67" Y2="55" Stroke="#999" StrokeThickness="0.5"/>
                                        <!-- A寸法線（柱中心→内側矩形端） -->
                                        <Line X1="67" Y1="12" X2="110" Y2="12" Stroke="#CC0000" StrokeThickness="1"/>
                                        <Ellipse Canvas.Left="65" Canvas.Top="10" Width="4" Height="4" Fill="#CC0000"/>
                                        <Ellipse Canvas.Left="108" Canvas.Top="10" Width="4" Height="4" Fill="#CC0000"/>
                                        <Line X1="110" Y1="12" X2="110" Y2="40" Stroke="#CC0000" StrokeThickness="0.5"
                                              StrokeDashArray="2 2"/>
                                        <TextBlock Canvas.Left="82" Canvas.Top="0" Text="A" FontSize="11"
                                                   Foreground="#CC0000" FontWeight="Bold"/>
                                        <!-- B寸法線（内側端→外側端） -->
                                        <Line X1="110" Y1="12" X2="125" Y2="12" Stroke="#0000CC" StrokeThickness="1"/>
                                        <Ellipse Canvas.Left="108" Canvas.Top="10" Width="4" Height="4" Fill="#0000CC"/>
                                        <Ellipse Canvas.Left="123" Canvas.Top="10" Width="4" Height="4" Fill="#0000CC"/>
                                        <Line X1="125" Y1="12" X2="125" Y2="25" Stroke="#0000CC" StrokeThickness="0.5"
                                              StrokeDashArray="2 2"/>
                                        <TextBlock Canvas.Left="113" Canvas.Top="0" Text="B" FontSize="11"
                                                   Foreground="#0000CC" FontWeight="Bold"/>
                                    </Canvas>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- 表示設定 -->
                    <Border Background="White" BorderBrush="#D3D3D3"
                            BorderThickness="1" CornerRadius="3" Padding="15,12" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionHeader}" Text="表示設定"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource LabelStyle}"
                                           Text="境界線の線種:" VerticalAlignment="Center"/>
                                <ComboBox Grid.Row="0" Grid.Column="1" x:Name="LineStyleComboBox"
                                          Style="{StaticResource ComboBoxStyle}"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource LabelStyle}"
                                           Text="塗り潰し領域パターン:" VerticalAlignment="Center"/>
                                <ComboBox Grid.Row="2" Grid.Column="1" x:Name="FillPatternComboBox"
                                          Style="{StaticResource ComboBoxStyle}"/>
                                <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource LabelStyle}"
                                           Text="凡例の文字タイプ:" VerticalAlignment="Center"/>
                                <ComboBox Grid.Row="4" Grid.Column="1" x:Name="TextNoteTypeComboBox"
                                          Style="{StaticResource ComboBoxStyle}"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Step 3: 確認・実行 -->
            <ScrollViewer x:Name="Step3Panel" Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Background="White" BorderBrush="#D3D3D3"
                            BorderThickness="1" CornerRadius="3" Padding="15,12" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionHeader}" Text="処理概要"/>
                            <TextBlock x:Name="SummaryText" Style="{StaticResource LabelStyle}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                    <Border Background="White" BorderBrush="#D3D3D3"
                            BorderThickness="1" CornerRadius="3" Padding="15,12" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionHeader}" Text="処理内容"/>
                            <CheckBox Content="耐火被覆種類ごとの塗潰領域タイプ作成" IsChecked="True" IsEnabled="False" Margin="0,3"/>
                            <CheckBox Content="要素周囲に塗潰領域を自動配置（重なり部分は統合）" IsChecked="True" IsEnabled="False" Margin="0,3"/>
                            <CheckBox Content="凡例の製図ビュー作成" IsChecked="True" IsEnabled="False" Margin="0,3"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#FFF8E1" BorderBrush="#FFD54F"
                            BorderThickness="1" CornerRadius="3" Padding="15,12">
                        <StackPanel>
                            <TextBlock FontSize="12" FontWeight="Bold" Foreground="#F57F17"
                                       Text="既存の耐火被覆について" Margin="0,0,0,5"/>
                            <CheckBox x:Name="OverwriteCheckBox" IsChecked="True"
                                      Content="既存の「耐火被覆_」塗潰領域・凡例を上書きする" FontSize="11" Margin="0,3"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Button Area -->
        <Border Grid.Row="2" Background="White" BorderBrush="#D3D3D3"
                BorderThickness="0,1,0,0" Padding="20,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BackButton" Content="戻る"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="BackButton_Click" IsEnabled="False"/>
                <Button x:Name="NextButton" Content="次へ"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="NextButton_Click"/>
                <Button Content="キャンセル"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="CancelButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
