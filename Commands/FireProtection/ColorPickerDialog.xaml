<Window x:Class="Tools28.Commands.FireProtection.ColorPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="色"
        Width="490" Height="340"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0"
        KeyDown="Window_KeyDown">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 基本色 -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="基本色(B):" FontSize="11" Margin="0,0,0,4"/>
        <UniformGrid Grid.Row="1" Grid.Column="0" Rows="6" Columns="8"
                     x:Name="BasicColorGrid" Margin="0,0,10,8"/>

        <!-- 作成した色 -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="作成した色(C):" FontSize="11" Margin="0,0,0,4"/>
        <UniformGrid Grid.Row="3" Grid.Column="0" Rows="2" Columns="8"
                     x:Name="CustomColorGrid" Margin="0,0,10,0"
                     VerticalAlignment="Top" Height="44"/>

        <!-- 右側: RGB入力 + プレビュー -->
        <StackPanel Grid.Row="0" Grid.RowSpan="4" Grid.Column="1">
            <!-- プレビュー -->
            <Grid Margin="0,16,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock Text="現在の色" FontSize="10" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                    <Border Width="80" Height="40" BorderBrush="#999" BorderThickness="1">
                        <Rectangle x:Name="CurrentColorPreview"/>
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock Text="新規の色" FontSize="10" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                    <Border Width="80" Height="40" BorderBrush="#999" BorderThickness="1">
                        <Rectangle x:Name="NewColorPreview"/>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- RGB入力 -->
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="55"/>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="55"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="赤(R):" FontSize="11" VerticalAlignment="Center"/>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="RedInput" FontSize="11" Height="22"
                         Padding="2,1" TextChanged="RGB_Changed"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="緑(G):" FontSize="11" VerticalAlignment="Center"/>
                <TextBox Grid.Row="2" Grid.Column="1" x:Name="GreenInput" FontSize="11" Height="22"
                         Padding="2,1" TextChanged="RGB_Changed"/>
                <TextBlock Grid.Row="4" Grid.Column="0" Text="青(U):" FontSize="11" VerticalAlignment="Center"/>
                <TextBox Grid.Row="4" Grid.Column="1" x:Name="BlueInput" FontSize="11" Height="22"
                         Padding="2,1" TextChanged="RGB_Changed"/>

                <TextBlock Grid.Row="0" Grid.Column="3" Text="名前:" FontSize="11" VerticalAlignment="Center"/>
                <TextBlock Grid.Row="0" Grid.Column="4" x:Name="ColorNameText" FontSize="10"
                           VerticalAlignment="Center" TextWrapping="Wrap"/>
            </Grid>

            <!-- 追加ボタン -->
            <Button Content="追加(A)" Width="80" Height="24" FontSize="11"
                    HorizontalAlignment="Left" Click="AddCustomColor_Click"/>
        </StackPanel>

        <!-- ボタンエリア -->
        <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button Content="OK" Width="75" Height="26" FontSize="11"
                    Margin="0,0,8,0" Click="OK_Click" IsDefault="True"/>
            <Button Content="キャンセル" Width="75" Height="26" FontSize="11"
                    Click="Cancel_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
