<Window x:Class="Tools28.Commands.LineStyleCheck.LineStyleCheckDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="線種変更確認"
        Width="340"
        Height="380"
        MinWidth="300"
        MinHeight="340"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="#F5F5F5"
        Topmost="True"
        Closing="Window_Closing">

    <Window.Resources>
        <SolidColorBrush x:Key="AccentBlue" Color="#0066CC"/>
        <SolidColorBrush x:Key="HoverBlue" Color="#0052A3"/>
        <SolidColorBrush x:Key="DarkGray" Color="#333333"/>
        <SolidColorBrush x:Key="LightGray" Color="#E6E6E6"/>
        <SolidColorBrush x:Key="HighlightRed" Color="#E05858"/>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource DarkGray}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="BorderBrush" Value="{StaticResource LightGray}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="90"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Background" Value="{StaticResource AccentBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource HoverBlue}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource HoverBlue}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="{StaticResource LightGray}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource LightGray}"/>
                    <Setter Property="Foreground" Value="#999999"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="90"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource DarkGray}"/>
            <Setter Property="BorderBrush" Value="#ADADAD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E5F3FF"/>
                    <Setter Property="BorderBrush" Value="#0078D7"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 検出結果サマリ -->
        <Border Grid.Row="0"
                Background="#FFF3F3"
                BorderBrush="{StaticResource HighlightRed}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="12,10"
                Margin="0,0,0,14">
            <StackPanel>
                <TextBlock FontSize="14" FontWeight="Bold"
                           Foreground="{StaticResource HighlightRed}">
                    <Run x:Name="DetectedCountRun" Text="0"/>
                    <Run Text="箇所の線種変更を検出"/>
                </TextBlock>
                <TextBlock x:Name="DetailText"
                           FontSize="10"
                           Foreground="#666666"
                           Margin="0,4,0,0"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- 検出要素リスト -->
        <StackPanel Grid.Row="1" Margin="0,0,0,6">
            <TextBlock Text="検出された要素:" Style="{StaticResource LabelStyle}"/>
        </StackPanel>

        <ListView Grid.Row="2"
                  x:Name="ElementListView"
                  Margin="0,0,0,14"
                  FontSize="11"
                  BorderBrush="{StaticResource LightGray}"
                  BorderThickness="1">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="カテゴリ" Width="100"
                                    DisplayMemberBinding="{Binding CategoryName}"/>
                    <GridViewColumn Header="変更線種" Width="90"
                                    DisplayMemberBinding="{Binding OverriddenStyleDisplay}"/>
                    <GridViewColumn Header="辺数" Width="40"
                                    DisplayMemberBinding="{Binding OverriddenEdgeCount}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- 線種選択 -->
        <StackPanel Grid.Row="3" Margin="0,0,0,14">
            <TextBlock Text="変更先の線種:" Style="{StaticResource LabelStyle}"/>
            <ComboBox x:Name="LineStyleComboBox"
                      Style="{StaticResource ComboBoxStyle}"
                      DisplayMemberPath="Name"/>
        </StackPanel>

        <!-- ボタンエリア -->
        <Grid Grid.Row="4" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1"
                    Content="一括変更"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="ChangeAllButton_Click"
                    x:Name="ChangeAllButton"/>
            <Button Grid.Column="3"
                    Content="選択変更"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="PickChangeButton_Click"
                    x:Name="PickChangeButton"/>
        </Grid>

        <!-- フッタ -->
        <Grid Grid.Row="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="再スキャン"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="RescanButton_Click"
                    MinWidth="75"/>
            <Button Grid.Column="2"
                    Content="閉じる"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="CloseButton_Click"
                    MinWidth="75"/>
        </Grid>
    </Grid>
</Window>
