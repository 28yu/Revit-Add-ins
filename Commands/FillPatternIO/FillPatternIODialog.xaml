<Window x:Class="Tools28.Commands.FillPatternIO.FillPatternIODialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="塗潰しパターン"
        Height="560" Width="580"
        MinHeight="440" MinWidth="500"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- パターンタイプ -->
        <GroupBox x:Name="grpFilter" Header="パターン タイプ" Grid.Row="0" Padding="8" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="RadioDrafting" GroupName="Filter" Content="製図"
                             IsChecked="True" Margin="0,0,18,0" Checked="Filter_Changed"/>
                <RadioButton x:Name="RadioModel" GroupName="Filter" Content="モデル"
                             Checked="Filter_Changed"/>
            </StackPanel>
        </GroupBox>

        <!-- 検索 -->
        <DockPanel Grid.Row="1" Margin="0,0,0,8">
            <TextBlock x:Name="txtSearchLabel" Text="検索:" VerticalAlignment="Center"
                       Margin="0,0,8,0" DockPanel.Dock="Left"/>
            <TextBox x:Name="SearchBox" Height="24" VerticalContentAlignment="Center"
                     TextChanged="SearchBox_TextChanged"/>
        </DockPanel>

        <!-- 全選択操作 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,6">
            <Button x:Name="btnSelectAll" Content="全選択" Width="72" Height="24"
                    Margin="0,0,6,0" Click="SelectAll_Click"/>
            <Button x:Name="btnClearAll" Content="全解除" Width="72" Height="24"
                    Click="ClearAll_Click"/>
            <TextBlock x:Name="txtCount" VerticalAlignment="Center" Margin="14,0,0,0"
                       Foreground="Gray"/>
        </StackPanel>

        <!-- パターン一覧（仮想化: 画面内の行だけプレビューを生成） -->
        <ListView x:Name="ListPatterns" Grid.Row="3"
                  VirtualizingStackPanel.IsVirtualizing="True"
                  VirtualizingStackPanel.VirtualizationMode="Recycling"
                  ScrollViewer.CanContentScroll="True">
            <ListView.View>
                <GridView>
                    <GridViewColumn Width="42">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                          HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn x:Name="colName" Header="名前" Width="260"
                                    DisplayMemberBinding="{Binding Name}"/>
                    <GridViewColumn x:Name="colPreview" Header="パターン" Width="234">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#DDDDDD" BorderThickness="1" Background="White">
                                    <Image Source="{Binding Preview}" Width="220" Height="26"
                                           Stretch="None" SnapsToDevicePixels="True"
                                           ToolTipService.InitialShowDelay="300"
                                           ToolTipService.BetweenShowDelay="0">
                                        <Image.ToolTip>
                                            <StackPanel Background="White">
                                                <TextBlock Text="{Binding Name}" FontWeight="Bold"
                                                           Margin="2,2,2,6"/>
                                                <Border BorderBrush="#AAAAAA" BorderThickness="1"
                                                        Background="White">
                                                    <Image Source="{Binding LargePreview}"
                                                           Width="440" Height="140"
                                                           Stretch="None" SnapsToDevicePixels="True"/>
                                                </Border>
                                            </StackPanel>
                                        </Image.ToolTip>
                                    </Image>
                                </Border>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- 単位選択 -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,8,0,10">
            <TextBlock x:Name="txtUnitLabel" Text="単位:" VerticalAlignment="Center"
                       Margin="0,0,8,0"/>
            <ComboBox x:Name="ComboUnit" Width="120" Height="24" SelectedIndex="0">
                <ComboBoxItem Content="mm"/>
                <ComboBoxItem Content="inch"/>
            </ComboBox>
        </StackPanel>

        <!-- アクションボタン -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="btnExport" Content="エクスポート" Width="112" Height="30"
                    Margin="0,0,8,0" Click="Export_Click"/>
            <Button x:Name="btnImport" Content="インポート" Width="112" Height="30"
                    Margin="0,0,8,0" Click="Import_Click"/>
            <Button x:Name="btnClose" Content="閉じる" Width="92" Height="30"
                    IsCancel="True" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
